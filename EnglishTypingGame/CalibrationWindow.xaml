<Window x:Class="EnglishTypingGame.CalibrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🎯 НАСТРОЙКА СКОРОСТИ" Height="400" Width="550"
        WindowStartupLocation="CenterOwner" Background="#2C2C3E">
    <Grid>
        <Border Background="#3A3A4A" CornerRadius="15" Margin="20">
            <StackPanel Margin="25">
                <TextBlock Text="НАСТРОЙКА РИТМА" FontSize="24" FontWeight="Bold"
                           Foreground="#FFD966" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <TextBlock Text="Игра подстроится под вашу скорость печати" 
                           Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,20"
                           TextWrapping="Wrap" TextAlignment="Center"/>

                <Border Background="#2D2D3D" CornerRadius="10" Padding="20" Margin="0,0,0,20">
                    <TextBlock x:Name="WordToType" Text="cat" FontSize="42" FontWeight="Bold"
                               Foreground="#FFD966" HorizontalAlignment="Center"/>
                </Border>

                <TextBlock Text="Введите слово и нажмите ENTER" 
                           Foreground="#AAAAAA" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <TextBox x:Name="InputBox" Height="45" FontSize="22" 
                         HorizontalAlignment="Center" Width="220" Margin="0,0,0,20"
                         BorderBrush="#FFD966" BorderThickness="2"
                         KeyDown="InputBox_KeyDown"/>

                <TextBlock x:Name="StatusText" Text="Попытка 1 из 3" 
                           Foreground="#FFD966" HorizontalAlignment="Center"/>

                <ProgressBar x:Name="CalibProgress" Height="8" Margin="0,15,0,0" 
                             Background="#555" Foreground="#4A90E2"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
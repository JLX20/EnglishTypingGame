<Window x:Class="EnglishTypingGame.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Обычная игра"
        Height="720"
        Width="1020"
        MinHeight="680"
        MinWidth="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Loaded="Window_Loaded"
        Background="{DynamicResource WindowBgBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <TextBlock x:Name="ModeTitleText"
                           FontSize="{DynamicResource TitleFontSize}"
                           FontWeight="Bold"
                           TextWrapping="Wrap"/>

                <TextBlock x:Name="ProgressText"
                           FontSize="{DynamicResource SmallFontSize}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Margin="0,4,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <Border Grid.Column="1"
                    Background="{DynamicResource CardBgBrush}"
                    CornerRadius="24"
                    Padding="16,10"
                    Effect="{StaticResource SoftShadow}"
                    VerticalAlignment="Center">

                <StackPanel>
                    <TextBlock x:Name="TimerText"
                               FontSize="{DynamicResource NormalFontSize}"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               MinWidth="140"/>

                    <TextBlock x:Name="ScoreText"
                               FontSize="{DynamicResource NormalFontSize}"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="1"
                Background="{DynamicResource CardBgBrush}"
                CornerRadius="30"
                Padding="24"
                Effect="{StaticResource CardShadow}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1.05*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="0.95*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ProgressBar x:Name="RoundProgressBar"
                             Grid.Row="0"
                             Minimum="0"
                             Maximum="100"
                             Margin="0,0,0,14"/>

                <Border Grid.Row="1"
                        Background="{DynamicResource SoftBgBrush}"
                        CornerRadius="26"
                        Padding="18"
                        Margin="0,0,0,14">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="PromptTitleText"
                                   Grid.Row="0"
                                   FontSize="{DynamicResource NormalFontSize}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8"/>

                        <Viewbox Grid.Row="1"
                                 Stretch="Uniform"
                                 StretchDirection="DownOnly">

                            <TextBlock x:Name="BigPromptText"
                                       Width="840"
                                       FontSize="{DynamicResource PromptFontSize}"
                                       FontWeight="Bold"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </Viewbox>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Background="{DynamicResource SoftBgBrush}"
                        CornerRadius="24"
                        Padding="16"
                        Margin="0,0,0,14">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Твой ответ:"
                                   FontSize="{DynamicResource NormalFontSize}"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>

                        <TextBox x:Name="InputBox"
                                 Grid.Row="1"
                                 Height="64"
                                 MinHeight="64"
                                 FontSize="{DynamicResource InputFontSize}"
                                 TextChanged="InputBox_TextChanged"
                                 KeyDown="InputBox_KeyDown"/>
                    </Grid>
                </Border>

                <Border Grid.Row="3"
                        Background="{DynamicResource SoftBgBrush}"
                        CornerRadius="24"
                        Padding="16"
                        Margin="0,0,0,14">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Проверка по буквам:"
                                   FontSize="{DynamicResource NormalFontSize}"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>

                        <Viewbox Grid.Row="1"
                                 Stretch="Uniform"
                                 StretchDirection="DownOnly">

                            <TextBlock x:Name="WordPreviewText"
                                       Width="840"
                                       FontSize="{DynamicResource PreviewFontSize}"
                                       FontWeight="Bold"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </Viewbox>
                    </Grid>
                </Border>

                <Border Grid.Row="4"
                        Background="{DynamicResource SoftBgBrush}"
                        CornerRadius="22"
                        Padding="12"
                        Margin="0,0,0,14">

                    <TextBlock x:Name="FeedbackText"
                               FontSize="{DynamicResource NormalFontSize}"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>
                </Border>

                <WrapPanel Grid.Row="5"
                           HorizontalAlignment="Right">

                    <Button x:Name="CheckButton"
                            Content="Проверить Enter"
                            Width="180"
                            Height="48"
                            Background="{DynamicResource ButtonMainBrush}"
                            Click="CheckButton_Click"/>

                    <Button x:Name="DontKnowButton"
                            Content="Не знаю"
                            Width="120"
                            Height="48"
                            Background="{DynamicResource ButtonWarningBrush}"
                            Click="DontKnowButton_Click"/>

                    <Button Content="Выйти"
                            Width="120"
                            Height="48"
                            Background="{DynamicResource ButtonNeutralBrush}"
                            Click="ExitButton_Click"/>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
<Window x:Class="EnglishTypingGame.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Обычная игра"
        Height="790"
        Width="960"
        MinHeight="650"
        MinWidth="820"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Loaded="Window_Loaded"
        Background="{DynamicResource WindowBgBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <TextBlock x:Name="ModeTitleText"
                           FontSize="30"
                           FontWeight="Bold"
                           TextWrapping="Wrap"/>

                <TextBlock x:Name="ProgressText"
                           FontSize="15"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Margin="0,4,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <Border Grid.Column="1"
                    Background="{DynamicResource CardBgBrush}"
                    CornerRadius="24"
                    Padding="16,10"
                    Effect="{StaticResource SoftShadow}"
                    VerticalAlignment="Center">

                <StackPanel>
                    <TextBlock x:Name="TimerText"
                               FontSize="16"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               MinWidth="140"/>

                    <TextBlock x:Name="ScoreText"
                               FontSize="16"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Главная карточка игры -->
        <Border Grid.Row="1"
                Background="{DynamicResource CardBgBrush}"
                CornerRadius="30"
                Padding="26"
                Effect="{StaticResource CardShadow}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ProgressBar x:Name="RoundProgressBar"
                             Grid.Row="0"
                             Height="14"
                             Minimum="0"
                             Maximum="100"
                             Margin="0,0,0,18"/>

                <TextBlock x:Name="PromptTitleText"
                           Grid.Row="1"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="820"/>

                <TextBlock x:Name="BigPromptText"
                           Grid.Row="2"
                           FontSize="44"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="820"
                           Margin="0,10,0,18"/>

                <!-- Поле ввода всегда видно -->
                <Border Grid.Row="3"
                        Background="{DynamicResource SoftBgBrush}"
                        CornerRadius="24"
                        Padding="18"
                        MaxWidth="820"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,16">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Твой ответ:"
                                   Grid.Row="0"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>

                        <TextBox x:Name="InputBox"
                                 Grid.Row="1"
                                 Height="68"
                                 FontSize="24"
                                 FontWeight="SemiBold"
                                 Foreground="{DynamicResource DarkTextBrush}"
                                 Background="White"
                                 BorderThickness="1"
                                 BorderBrush="#CBD5E1"
                                 Padding="16,8"
                                 TextChanged="InputBox_TextChanged"
                                 KeyDown="InputBox_KeyDown"/>
                    </Grid>
                </Border>

                <!-- Проверка букв -->
                <Border Grid.Row="4"
                        Background="{DynamicResource SoftBgBrush}"
                        CornerRadius="24"
                        Padding="18"
                        MaxWidth="820"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,16">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Проверка по буквам:"
                                   Grid.Row="0"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>

                        <TextBlock x:Name="WordPreviewText"
                                   Grid.Row="1"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="780"/>
                    </Grid>
                </Border>

                <Border Grid.Row="5"
                        Background="{DynamicResource SoftBgBrush}"
                        CornerRadius="22"
                        Padding="12"
                        VerticalAlignment="Stretch"
                        Margin="0,0,0,16">

                    <TextBlock x:Name="FeedbackText"
                               FontSize="17"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>
                </Border>

                <WrapPanel Grid.Row="6"
                           HorizontalAlignment="Right">

                    <Button x:Name="CheckButton"
                            Content="Проверить Enter"
                            Width="180"
                            Height="48"
                            Background="{DynamicResource ButtonMainBrush}"
                            Click="CheckButton_Click"/>

                    <Button Content="Выйти"
                            Width="120"
                            Height="48"
                            Background="{DynamicResource ButtonNeutralBrush}"
                            Click="ExitButton_Click"/>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
<Window x:Class="EnglishTypingGame.MiniGameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Мини-игра"
        Height="740"
        Width="1040"
        MinHeight="640"
        MinWidth="780"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown"
        Background="{DynamicResource WindowBgBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Margin="0,0,16,0">

                <TextBlock x:Name="TitleText"
                           FontSize="34"
                           FontWeight="Bold"
                           TextWrapping="Wrap"/>

                <TextBlock x:Name="DescriptionText"
                           FontSize="16"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <Border Grid.Column="1"
                    Background="{DynamicResource CardBgBrush}"
                    CornerRadius="24"
                    Padding="16,10"
                    Effect="{StaticResource SoftShadow}"
                    VerticalAlignment="Center">

                <StackPanel>
                    <TextBlock x:Name="TimerText"
                               FontSize="16"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MinWidth="150"/>

                    <TextBlock x:Name="ScoreText"
                               FontSize="16"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="1"
                Background="{DynamicResource CardBgBrush}"
                CornerRadius="30"
                Padding="24"
                Effect="{StaticResource CardShadow}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ProgressBar x:Name="ProgressBar"
                             Height="14"
                             Minimum="0"
                             Maximum="100"
                             Margin="0,0,0,18"/>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">

                    <Grid>
                        <StackPanel x:Name="GamePanel"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    MaxWidth="860"
                                    Margin="8"/>
                    </Grid>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Background="{DynamicResource SoftBgBrush}"
                        CornerRadius="22"
                        Padding="14"
                        Margin="0,16,0,0">

                    <TextBlock x:Name="FeedbackText"
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               MaxWidth="820"/>
                </Border>
            </Grid>
        </Border>

        <WrapPanel Grid.Row="2"
                   HorizontalAlignment="Right"
                   Margin="0,16,0,0">

            <Button Content="Завершить"
                    Width="135"
                    Height="48"
                    Background="{DynamicResource ButtonNeutralBrush}"
                    Click="FinishButton_Click"/>

            <Button Content="Закрыть"
                    Width="120"
                    Height="48"
                    Background="{DynamicResource ButtonNeutralBrush}"
                    Click="CloseButton_Click"/>
        </WrapPanel>
    </Grid>
</Window>
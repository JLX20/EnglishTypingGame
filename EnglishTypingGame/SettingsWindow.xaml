<Window x:Class="EnglishTypingGame.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚙ НАСТРОЙКИ" Height="550" Width="500"
        WindowStartupLocation="CenterOwner" Background="#2C2C3E">
    <Grid>
        <Border Background="#3A3A4A" CornerRadius="15" Margin="20">
            <StackPanel Margin="30">
                <TextBlock Text="НАСТРОЙКИ" FontSize="28" FontWeight="Bold"
                           Foreground="#FFD966" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                <!-- Громкость -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="🔊 Громкость эффектов" Foreground="White" FontSize="16"
                               Margin="0,0,0,10"/>
                    <Slider x:Name="VolumeSlider" Minimum="0" Maximum="100" 
                            Value="50" TickFrequency="10" Margin="0,5"/>
                </StackPanel>

                <!-- Сложность -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="🎚 Сложность по умолчанию" Foreground="White" FontSize="16"
                               Margin="0,0,0,10"/>
                    <ComboBox x:Name="DifficultyCombo" Height="35" FontSize="14" Margin="0,5">
                        <ComboBoxItem Content="Лёгкая (медленнее на 30%)"/>
                        <ComboBoxItem Content="Средняя (стандарт)" IsSelected="True"/>
                        <ComboBoxItem Content="Сложная (быстрее на 30%)"/>
                    </ComboBox>
                </StackPanel>

                <!-- Сброс прогресса -->
                <Button Content="🔄 СБРОСИТЬ ВЕСЬ ПРОГРЕСС" Width="250" Height="45"
                        Background="#E2542E" Foreground="White" FontSize="16"
                        Cursor="Hand" Click="ResetProgress_Click" Margin="0,10,0,0"/>

                <Button Content="💾 СОХРАНИТЬ НАСТРОЙКИ" Width="250" Height="45"
                        Background="#50C878" Foreground="White" FontSize="16"
                        Cursor="Hand" Click="SaveSettings_Click" Margin="0,20,0,0"/>

                <Button Content="🔙 ЗАКРЫТЬ" Width="150" Height="35"
                        Background="#888888" Foreground="White" FontSize="14"
                        Cursor="Hand" Click="Close_Click" Margin="0,20,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
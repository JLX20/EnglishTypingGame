<Window x:Class="EnglishTypingGame.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки"
        Height="760"
        Width="740"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBgBrush}">

    <Grid Margin="30">
        <Border Background="{DynamicResource CardBgBrush}"
                CornerRadius="30"
                Padding="28"
                Effect="{StaticResource CardShadow}">

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Настройки"
                               FontSize="32"
                               FontWeight="Bold"
                               Margin="0,0,0,24"/>

                    <TextBlock Text="Цветовая тема интерфейса"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <ComboBox x:Name="ThemeComboBox"
                              Height="46"
                              Margin="0,8,0,18">
                        <ComboBoxItem Content="Blue — синяя тема" Tag="Blue"/>
                        <ComboBoxItem Content="Green — зелёная тема" Tag="Green"/>
                        <ComboBoxItem Content="Purple — фиолетовая тема" Tag="Purple"/>
                        <ComboBoxItem Content="Orange — оранжевая тема" Tag="Orange"/>
                        <ComboBoxItem Content="Dark — тёмная тема" Tag="Dark"/>
                    </ComboBox>

                    <TextBlock Text="Фон всей программы"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <ComboBox x:Name="BackgroundComboBox"
                              Height="46"
                              Margin="0,8,0,18">
                        <ComboBoxItem Content="Sky — небо" Tag="Sky"/>
                        <ComboBoxItem Content="Plain — простой светлый" Tag="Plain"/>
                        <ComboBoxItem Content="Mint — мятный" Tag="Mint"/>
                        <ComboBoxItem Content="Sunset — закат" Tag="Sunset"/>
                        <ComboBoxItem Content="Lavender — лаванда" Tag="Lavender"/>
                        <ComboBoxItem Content="Night — ночной" Tag="Night"/>
                    </ComboBox>

                    <Separator Margin="0,8,0,20"/>

                    <TextBlock Text="Слов в обычном раунде"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <ComboBox x:Name="WordsPerRoundComboBox"
                              Height="46"
                              Margin="0,8,0,18">
                        <ComboBoxItem Content="5"/>
                        <ComboBoxItem Content="10"/>
                        <ComboBoxItem Content="15"/>
                        <ComboBoxItem Content="20"/>
                    </ComboBox>

                    <TextBlock Text="Длительность Word Rain"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <ComboBox x:Name="RainSecondsComboBox"
                              Height="46"
                              Margin="0,8,0,18">
                        <ComboBoxItem Content="30"/>
                        <ComboBoxItem Content="60"/>
                        <ComboBoxItem Content="90"/>
                        <ComboBoxItem Content="120"/>
                    </ComboBox>

                    <Separator Margin="0,8,0,20"/>

                    <TextBlock Text="Word Rain / Cloud Mode"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <CheckBox x:Name="CloudModeCheckBox"
                              Content="Режим облаков: слова летят в облаках"/>

                    <CheckBox x:Name="VisualEffectsCheckBox"
                              Content="Визуальные эффекты при правильном ответе"/>

                    <TextBlock x:Name="FallSpeedValueText"
                               FontSize="15"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="0,14,0,6"/>

                    <Slider x:Name="FallSpeedSlider"
                            Minimum="0.5"
                            Maximum="2.5"
                            TickFrequency="0.1"
                            IsSnapToTickEnabled="True"
                            ValueChanged="FallSpeedSlider_ValueChanged"
                            Margin="0,0,0,16"/>

                    <TextBlock x:Name="SpawnSpeedValueText"
                               FontSize="15"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="0,0,0,6"/>

                    <Slider x:Name="SpawnSpeedSlider"
                            Minimum="700"
                            Maximum="2500"
                            TickFrequency="100"
                            IsSnapToTickEnabled="True"
                            ValueChanged="SpawnSpeedSlider_ValueChanged"
                            Margin="0,0,0,16"/>

                    <CheckBox x:Name="SlowModeCheckBox"
                              Content="Дополнительный медленный режим Word Rain"/>

                    <CheckBox x:Name="SoundCheckBox"
                              Content="Звуковые сигналы"/>

                    <CheckBox x:Name="ExamplesCheckBox"
                              Content="Показывать примеры предложений"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,30,0,0">

                        <Button Content="Сохранить"
                                Width="135"
                                Height="48"
                                Background="{DynamicResource ButtonMainBrush}"
                                Click="SaveButton_Click"/>

                        <Button Content="Отмена"
                                Width="120"
                                Height="48"
                                Background="{DynamicResource ButtonNeutralBrush}"
                                Click="CancelButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
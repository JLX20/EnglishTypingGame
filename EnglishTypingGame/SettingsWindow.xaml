<Window x:Class="EnglishTypingGame.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки"
        Height="650"
        Width="740"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBgBrush}">

    <Grid Margin="30">
        <Border Background="{DynamicResource CardBgBrush}"
                CornerRadius="30"
                Padding="28"
                Effect="{StaticResource CardShadow}">

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">

                <StackPanel>
                    <TextBlock Text="Настройки"
                               FontSize="{DynamicResource TitleFontSize}"
                               FontWeight="Bold"
                               Margin="0,0,0,24"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="Цветовая тема интерфейса"
                               FontSize="{DynamicResource NormalFontSize}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"/>

                    <ComboBox x:Name="ThemeComboBox"
                              Height="46"
                              Margin="0,8,0,18">
                        <ComboBoxItem Content="Blue — синяя тема" Tag="Blue"/>
                        <ComboBoxItem Content="Green — зелёная тема" Tag="Green"/>
                        <ComboBoxItem Content="Purple — фиолетовая тема" Tag="Purple"/>
                        <ComboBoxItem Content="Orange — оранжевая тема" Tag="Orange"/>
                    </ComboBox>

                    <TextBlock Text="Фон всей программы"
                               FontSize="{DynamicResource NormalFontSize}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"/>

                    <ComboBox x:Name="BackgroundComboBox"
                              Height="46"
                              Margin="0,8,0,18">
                        <ComboBoxItem Content="Sky — небо" Tag="Sky"/>
                        <ComboBoxItem Content="Plain — простой светлый" Tag="Plain"/>
                        <ComboBoxItem Content="Mint — мятный" Tag="Mint"/>
                        <ComboBoxItem Content="Sunset — закат" Tag="Sunset"/>
                        <ComboBoxItem Content="Lavender — лаванда" Tag="Lavender"/>
                    </ComboBox>

                    <TextBlock Text="Размер букв во всей программе"
                               FontSize="{DynamicResource NormalFontSize}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"/>

                    <ComboBox x:Name="TextSizeComboBox"
                              Height="46"
                              Margin="0,8,0,18">
                        <ComboBoxItem Content="Small — маленькие буквы" Tag="Small"/>
                        <ComboBoxItem Content="Normal — обычные буквы" Tag="Normal"/>
                        <ComboBoxItem Content="Large — большие буквы" Tag="Large"/>
                        <ComboBoxItem Content="Extra Large — очень большие буквы" Tag="ExtraLarge"/>
                    </ComboBox>

                    <Separator Margin="0,8,0,20"/>

                    <TextBlock Text="Слов в обычном раунде"
                               FontSize="{DynamicResource NormalFontSize}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"/>

                    <ComboBox x:Name="WordsPerRoundComboBox"
                              Height="46"
                              Margin="0,8,0,18">
                        <ComboBoxItem Content="5"/>
                        <ComboBoxItem Content="10"/>
                        <ComboBoxItem Content="15"/>
                        <ComboBoxItem Content="20"/>
                    </ComboBox>

                    <Separator Margin="0,8,0,20"/>

                    <CheckBox x:Name="SlowModeCheckBox"
                              Content="Медленный режим обучения"/>

                    <CheckBox x:Name="SoundCheckBox"
                              Content="Звуковые сигналы"/>

                    <CheckBox x:Name="ExamplesCheckBox"
                              Content="Показывать примеры предложений в обучении"/>

                    <Border Background="{DynamicResource SoftBgBrush}"
                            CornerRadius="22"
                            Padding="16"
                            Margin="0,18,0,0">

                        
                    </Border>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,30,0,0">

                        <Button Content="Сохранить"
                                Width="135"
                                Height="48"
                                Background="{DynamicResource ButtonMainBrush}"
                                Click="SaveButton_Click"/>

                        <Button Content="Отмена"
                                Width="120"
                                Height="48"
                                Background="{DynamicResource ButtonNeutralBrush}"
                                Click="CancelButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
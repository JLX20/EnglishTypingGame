<Window x:Class="EnglishTypingGame.MiniGamesMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Мини-игры"
        Height="740"
        Width="1000"
        MinHeight="640"
        MinWidth="780"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource WindowBgBrush}">

    <Grid Margin="26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="Мини-игры"
                       FontSize="38"
                       FontWeight="Bold"
                       TextWrapping="Wrap"/>

            <TextBlock x:Name="TopicText"
                       FontSize="16"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Margin="0,6,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Main card -->
        <Border Grid.Row="1"
                Background="{DynamicResource CardBgBrush}"
                CornerRadius="30"
                Padding="24"
                Effect="{StaticResource CardShadow}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="0.9*"/>
                </Grid.ColumnDefinitions>

                <!-- Left side: filters and games list -->
                <Grid Grid.Column="0"
                      Margin="0,0,20,0">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Margin="0,0,0,14">

                        <TextBlock Text="Фильтр по разделам"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,6"/>

                        <ComboBox x:Name="SectionFilterComboBox"
                                  Height="46"
                                  SelectionChanged="SectionFilterComboBox_SelectionChanged">
                            <ComboBoxItem Content="Все разделы" Tag="Все"/>
                            <ComboBoxItem Content="Слова" Tag="Слова"/>
                            <ComboBoxItem Content="Грамматика" Tag="Грамматика"/>
                            <ComboBoxItem Content="Предложения" Tag="Предложения"/>
                            <ComboBoxItem Content="Числа и даты" Tag="Числа и даты"/>
                            <ComboBoxItem Content="Диалоги" Tag="Диалоги"/>
                        </ComboBox>

                        <TextBlock x:Name="GamesCountText"
                                   FontSize="14"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Background="{DynamicResource SoftBgBrush}"
                            CornerRadius="24"
                            Padding="10">

                        <ListBox x:Name="GamesListBox"
                                 FontSize="16"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 SelectionChanged="GamesListBox_SelectionChanged">

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="14"
                                            Margin="4"
                                            CornerRadius="22"
                                            Background="{DynamicResource CardBgBrush}"
                                            Effect="{StaticResource SoftShadow}">

                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="17"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"/>

                                            <TextBlock Text="{Binding Group}"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,3,0,0"/>

                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,6,0,0"
                                                       MaxHeight="48"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>

                <!-- Right side: selected game info -->
                <Border Grid.Column="1"
                        Background="{DynamicResource SoftBgBrush}"
                        CornerRadius="26"
                        Padding="22">

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">

                        <StackPanel>
                            <TextBlock x:Name="SelectedTitleText"
                                       FontSize="27"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"/>

                            <TextBlock x:Name="SelectedGroupText"
                                       FontSize="15"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,18"/>

                            <TextBlock x:Name="SelectedDescriptionText"
                                       FontSize="17"
                                       TextWrapping="Wrap"
                                       LineHeight="28"/>

                            <Separator Margin="0,24,0,18"/>

                            <TextBlock Text="Разделы:"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>

                            <TextBlock FontSize="15"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       TextWrapping="Wrap"
                                       LineHeight="26">
                                Слова — повторение слов из выбранной темы.&#x0a;
                                Грамматика — правила английского.&#x0a;
                                Предложения — сборка предложений.&#x0a;
                                Числа и даты — числа, дни, месяцы.&#x0a;
                                Диалоги — ответы в простых ситуациях.
                            </TextBlock>

                            <Separator Margin="0,22,0,18"/>

                            <TextBlock Text="Как заниматься:"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>

                            <TextBlock FontSize="15"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       TextWrapping="Wrap"
                                       LineHeight="26">
                                1. Сначала изучи слова.&#x0a;
                                2. Потом выбери мини-игру из раздела “Слова”.&#x0a;
                                3. После этого переходи к грамматике.&#x0a;
                                4. Ошибки сохраняются для повторения.
                            </TextBlock>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <!-- Bottom buttons -->
        <WrapPanel Grid.Row="2"
                   HorizontalAlignment="Right"
                   Margin="0,16,0,0">

            <Button Content="Начать мини-игру"
                    Width="175"
                    Height="48"
                    Background="{DynamicResource ButtonMainBrush}"
                    Click="StartButton_Click"/>

            <Button Content="Закрыть"
                    Width="120"
                    Height="48"
                    Background="{DynamicResource ButtonNeutralBrush}"
                    Click="CloseButton_Click"/>
        </WrapPanel>
    </Grid>
</Window>
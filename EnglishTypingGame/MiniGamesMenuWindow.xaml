<Window x:Class="EnglishTypingGame.MiniGamesMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Мини-игры"
        Height="760"
        Width="1080"
        MinHeight="700"
        MinWidth="940"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource WindowBgBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Мини-игры"
                       FontSize="{DynamicResource TitleFontSize}"
                       FontWeight="Bold"
                       TextWrapping="Wrap"/>

            <TextBlock x:Name="TopicText"
                       FontSize="{DynamicResource SubtitleFontSize}"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Margin="0,4,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="{DynamicResource CardBgBrush}"
                CornerRadius="30"
                Padding="22"
                Effect="{StaticResource CardShadow}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.15*"/>
                    <ColumnDefinition Width="0.85*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0"
                      Margin="0,0,20,0">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Margin="0,0,0,12">

                        <TextBlock Text="Фильтр по разделам"
                                   FontSize="{DynamicResource NormalFontSize}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,6"/>

                        <ComboBox x:Name="SectionFilterComboBox"
                                  Height="46"
                                  SelectionChanged="SectionFilterComboBox_SelectionChanged">
                            <ComboBoxItem Content="Все разделы" Tag="Все"/>
                            <ComboBoxItem Content="Слова" Tag="Слова"/>
                            <ComboBoxItem Content="Грамматика" Tag="Грамматика"/>
                            <ComboBoxItem Content="Предложения" Tag="Предложения"/>
                            <ComboBoxItem Content="Числа и даты" Tag="Числа и даты"/>
                            <ComboBoxItem Content="Диалоги" Tag="Диалоги"/>
                        </ComboBox>

                        <TextBlock x:Name="GamesCountText"
                                   FontSize="{DynamicResource SmallFontSize}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Background="{DynamicResource SoftBgBrush}"
                            CornerRadius="24"
                            Padding="10">

                        <ListBox x:Name="GamesListBox"
                                 FontSize="{DynamicResource NormalFontSize}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 SelectionChanged="GamesListBox_SelectionChanged">

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12"
                                            Margin="4"
                                            CornerRadius="22"
                                            Background="{DynamicResource CardBgBrush}"
                                            Effect="{StaticResource SoftShadow}">

                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="{DynamicResource NormalFontSize}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"/>

                                            <TextBlock Text="{Binding Group}"
                                                       FontSize="{DynamicResource SmallFontSize}"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,3,0,0"/>

                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="{DynamicResource SmallFontSize}"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,5,0,0"
                                                       MaxHeight="46"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>

                <Border Grid.Column="1"
                        Background="{DynamicResource SoftBgBrush}"
                        CornerRadius="26"
                        Padding="22">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="SelectedTitleText"
                                   Grid.Row="0"
                                   FontSize="{DynamicResource PromptFontSize}"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"/>

                        <TextBlock x:Name="SelectedGroupText"
                                   Grid.Row="1"
                                   FontSize="{DynamicResource NormalFontSize}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,14"/>

                        <TextBlock x:Name="SelectedDescriptionText"
                                   Grid.Row="2"
                                   FontSize="{DynamicResource NormalFontSize}"
                                   TextWrapping="Wrap"
                                   LineHeight="28"/>

                        <Border Grid.Row="3"
                                Background="{DynamicResource CardBgBrush}"
                                CornerRadius="20"
                                Padding="14"
                                Margin="0,14,0,0">

                            <TextBlock FontSize="{DynamicResource SmallFontSize}"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       TextWrapping="Wrap"
                                       LineHeight="24">
                                Выбери раздел слева, потом мини-игру. После изучения слов лучше начинать с раздела “Слова”.
                            </TextBlock>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <WrapPanel Grid.Row="2"
                   HorizontalAlignment="Right"
                   Margin="0,14,0,0">

            <Button Content="Начать мини-игру"
                    Width="175"
                    Height="48"
                    FontSize="{DynamicResource ButtonFontSize}"
                    Background="{DynamicResource ButtonMainBrush}"
                    Click="StartButton_Click"/>

            <Button Content="Закрыть"
                    Width="120"
                    Height="48"
                    FontSize="{DynamicResource ButtonFontSize}"
                    Background="{DynamicResource ButtonNeutralBrush}"
                    Click="CloseButton_Click"/>
        </WrapPanel>
    </Grid>
</Window>
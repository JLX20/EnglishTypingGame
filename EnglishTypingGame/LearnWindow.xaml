<Window x:Class="EnglishTypingGame.LearnWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Изучение слов"
        Height="720"
        Width="1020"
        MinHeight="680"
        MinWidth="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource WindowBgBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Изучение слов"
                       FontSize="{DynamicResource TitleFontSize}"
                       FontWeight="Bold"
                       TextWrapping="Wrap"/>

            <TextBlock x:Name="TopicText"
                       FontSize="{DynamicResource SubtitleFontSize}"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Margin="0,4,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="{DynamicResource CardBgBrush}"
                CornerRadius="30"
                Padding="24"
                Effect="{StaticResource CardShadow}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ProgressBar x:Name="LearnProgressBar"
                             Grid.Row="0"
                             Height="14"
                             Minimum="0"
                             Maximum="100"
                             Margin="0,0,0,14"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.15*"/>
                        <ColumnDefinition Width="0.85*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{DynamicResource SoftBgBrush}"
                            CornerRadius="26"
                            Padding="22"
                            Margin="0,0,18,0">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="WordCounterText"
                                       Grid.Row="0"
                                       FontSize="{DynamicResource NormalFontSize}"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Margin="0,0,0,12"/>

                            <Viewbox Grid.Row="1"
                                     Stretch="Uniform"
                                     StretchDirection="DownOnly"
                                     MaxHeight="260">

                                <StackPanel Width="580">
                                    <TextBlock x:Name="EnglishWordText"
                                               FontSize="{DynamicResource WordFontSize}"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               MaxWidth="560"/>

                                    <TextBlock x:Name="RussianWordText"
                                               FontSize="{DynamicResource PromptFontSize}"
                                               Foreground="{DynamicResource ButtonMainBrush}"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               MaxWidth="560"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Viewbox>

                            <TextBlock x:Name="LevelText"
                                       Grid.Row="2"
                                       FontSize="{DynamicResource NormalFontSize}"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,12,0,0"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{DynamicResource SoftBgBrush}"
                                CornerRadius="26"
                                Padding="20"
                                Margin="0,0,0,14">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="Пример"
                                           FontSize="{DynamicResource NormalFontSize}"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,8"/>

                                <TextBlock x:Name="ExampleText"
                                           Grid.Row="1"
                                           FontSize="{DynamicResource NormalFontSize}"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource DarkTextBrush}"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Background="{DynamicResource SoftBgBrush}"
                                CornerRadius="26"
                                Padding="18">

                            <StackPanel>
                                <TextBlock Text="Проверка: напиши это слово"
                                           FontSize="{DynamicResource NormalFontSize}"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           Margin="0,0,0,8"/>

                                <TextBox x:Name="PracticeBox"
                                         Height="58"
                                         FontSize="{DynamicResource InputFontSize}"
                                         Background="{DynamicResource InputBgBrush}"
                                         Foreground="{DynamicResource InputTextBrush}"
                                         CaretBrush="{DynamicResource InputTextBrush}"
                                         BorderBrush="{DynamicResource InputBorderBrush}"
                                         BorderThickness="2"
                                         TextChanged="PracticeBox_TextChanged"/>

                                <TextBlock x:Name="PracticeFeedbackText"
                                           FontSize="{DynamicResource NormalFontSize}"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <WrapPanel Grid.Row="2"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0">

                    <Button Content="← Назад"
                            Width="125"
                            Height="46"
                            FontSize="{DynamicResource ButtonFontSize}"
                            Background="{DynamicResource ButtonMainBrush}"
                            Click="PreviousButton_Click"/>

                    <Button Content="Я выучил слово"
                            Width="165"
                            Height="46"
                            FontSize="{DynamicResource ButtonFontSize}"
                            Background="{DynamicResource ButtonMainBrush}"
                            Click="LearnedButton_Click"/>

                    <Button Content="Дальше →"
                            Width="125"
                            Height="46"
                            FontSize="{DynamicResource ButtonFontSize}"
                            Background="{DynamicResource ButtonMainBrush}"
                            Click="NextButton_Click"/>
                </WrapPanel>
            </Grid>
        </Border>

        <WrapPanel Grid.Row="2"
                   HorizontalAlignment="Right"
                   Margin="0,14,0,0">

            <Button Content="Перейти к мини-играм"
                    Width="205"
                    Height="46"
                    FontSize="{DynamicResource ButtonFontSize}"
                    Background="{DynamicResource ButtonMainBrush}"
                    Click="MiniGamesButton_Click"/>

            <Button Content="Обычная игра"
                    Width="150"
                    Height="46"
                    FontSize="{DynamicResource ButtonFontSize}"
                    Background="{DynamicResource ButtonMainBrush}"
                    Click="StartGameButton_Click"/>

            <Button Content="В меню"
                    Width="110"
                    Height="46"
                    FontSize="{DynamicResource ButtonFontSize}"
                    Background="{DynamicResource ButtonNeutralBrush}"
                    Click="CloseButton_Click"/>
        </WrapPanel>
    </Grid>
</Window>
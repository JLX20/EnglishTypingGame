<Window x:Class="EnglishTypingGame.GrammarLearnWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Изучение правил"
        Height="760"
        Width="1120"
        MinHeight="700"
        MinWidth="980"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource WindowBgBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Изучение правил по урокам"
                       FontSize="{DynamicResource TitleFontSize}"
                       FontWeight="Bold"
                       TextWrapping="Wrap"/>

            <TextBlock x:Name="LessonDescriptionText"
                       FontSize="{DynamicResource SubtitleFontSize}"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="{DynamicResource CardBgBrush}"
                CornerRadius="30"
                Padding="22"
                Effect="{StaticResource CardShadow}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.9*"/>
                    <ColumnDefinition Width="1.35*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,20,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Урок"
                                   FontSize="{DynamicResource NormalFontSize}"
                                   FontWeight="SemiBold"/>

                        <ComboBox x:Name="LessonComboBox"
                                  Height="46"
                                  Margin="0,8,0,0"
                                  DisplayMemberPath="Title"
                                  SelectionChanged="LessonComboBox_SelectionChanged"/>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Background="{DynamicResource SoftBgBrush}"
                            CornerRadius="24"
                            Padding="10">

                        <ListBox x:Name="RulesListBox"
                                 SelectionChanged="RulesListBox_SelectionChanged"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource CardBgBrush}"
                                            CornerRadius="20"
                                            Padding="12"
                                            Margin="4"
                                            Effect="{StaticResource SoftShadow}">

                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="{DynamicResource NormalFontSize}"
                                                       FontWeight="Bold"
                                                       TextWrapping="Wrap"/>

                                            <TextBlock Text="{Binding Category}"
                                                       FontSize="{DynamicResource SmallFontSize}"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,0,0"/>

                                            <TextBlock Text="{Binding ShortExplanation}"
                                                       FontSize="{DynamicResource SmallFontSize}"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="58"
                                                       Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>

                <Border Grid.Column="1"
                        Background="{DynamicResource SoftBgBrush}"
                        CornerRadius="26"
                        Padding="18">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ScrollViewer Grid.Row="0"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">

                            <StackPanel>
                                <TextBlock x:Name="RuleTitleText"
                                           FontSize="{DynamicResource PromptFontSize}"
                                           FontWeight="Bold"
                                           TextWrapping="Wrap"/>

                                <TextBlock x:Name="RuleCategoryText"
                                           FontSize="{DynamicResource SmallFontSize}"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,14"/>

                                <TextBlock x:Name="ShortExplanationText"
                                           FontSize="{DynamicResource NormalFontSize}"
                                           TextWrapping="Wrap"
                                           LineHeight="27"
                                           Margin="0,0,0,14"/>

                                <TextBlock Text="Когда использовать"
                                           FontSize="{DynamicResource NormalFontSize}"
                                           FontWeight="Bold"/>

                                <TextBlock x:Name="WhenToUseText"
                                           FontSize="{DynamicResource NormalFontSize}"
                                           TextWrapping="Wrap"
                                           LineHeight="27"
                                           Margin="0,4,0,14"/>

                                <TextBlock Text="Формула / исключения"
                                           FontSize="{DynamicResource NormalFontSize}"
                                           FontWeight="Bold"/>

                                <TextBlock x:Name="FormulaText"
                                           FontSize="{DynamicResource NormalFontSize}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource ButtonMainBrush}"
                                           TextWrapping="Wrap"
                                           LineHeight="27"
                                           Margin="0,4,0,14"/>

                                <TextBlock Text="Примеры"
                                           FontSize="{DynamicResource NormalFontSize}"
                                           FontWeight="Bold"/>

                                <TextBlock x:Name="ExamplesText"
                                           FontSize="{DynamicResource NormalFontSize}"
                                           TextWrapping="Wrap"
                                           LineHeight="27"
                                           Margin="0,4,0,14"/>

                                <TextBlock Text="Частые ошибки"
                                           FontSize="{DynamicResource NormalFontSize}"
                                           FontWeight="Bold"/>

                                <TextBlock x:Name="CommonMistakesText"
                                           FontSize="{DynamicResource NormalFontSize}"
                                           TextWrapping="Wrap"
                                           LineHeight="27"/>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Row="1"
                                Background="{DynamicResource CardBgBrush}"
                                CornerRadius="20"
                                Padding="14"
                                Margin="0,12,0,0">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="PracticeQuestionText"
                                           Grid.Row="0"
                                           FontSize="{DynamicResource NormalFontSize}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8"/>

                                <TextBox x:Name="PracticeAnswerBox"
                                         Grid.Row="1"
                                         Height="52"
                                         FontSize="{DynamicResource InputFontSize}"
                                         Background="{DynamicResource InputBgBrush}"
                                         Foreground="{DynamicResource InputTextBrush}"
                                         CaretBrush="{DynamicResource InputTextBrush}"
                                         BorderBrush="{DynamicResource InputBorderBrush}"
                                         BorderThickness="2"
                                         KeyDown="PracticeAnswerBox_KeyDown"/>

                                <Grid Grid.Row="2" Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Content="Проверить"
                                            Width="130"
                                            Height="44"
                                            FontSize="{DynamicResource ButtonFontSize}"
                                            Background="{DynamicResource ButtonMainBrush}"
                                            Click="CheckPracticeButton_Click"/>

                                    <Button Grid.Column="1"
                                            Content="Показать ответ"
                                            Width="155"
                                            Height="44"
                                            FontSize="{DynamicResource ButtonFontSize}"
                                            Background="{DynamicResource ButtonNeutralBrush}"
                                            Click="ShowAnswerButton_Click"/>

                                    <TextBlock x:Name="PracticeFeedbackText"
                                               Grid.Column="2"
                                               FontSize="{DynamicResource SmallFontSize}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"
                                               Margin="10,0,0,0"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <WrapPanel Grid.Row="2"
                   HorizontalAlignment="Right"
                   Margin="0,14,0,0">

            <Button Content="К мини-играм"
                    Width="150"
                    Height="48"
                    FontSize="{DynamicResource ButtonFontSize}"
                    Background="{DynamicResource ButtonMainBrush}"
                    Click="MiniGamesButton_Click"/>

            <Button Content="В меню"
                    Width="120"
                    Height="48"
                    FontSize="{DynamicResource ButtonFontSize}"
                    Background="{DynamicResource ButtonNeutralBrush}"
                    Click="CloseButton_Click"/>
        </WrapPanel>
    </Grid>
</Window>
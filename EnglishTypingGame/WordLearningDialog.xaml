<Window x:Class="EnglishTypingGame.WordLearningDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📝 ИЗУЧЕНИЕ СЛОВА" Height="400" Width="550"
        WindowStartupLocation="CenterOwner" Background="#2D2D3D">
    <Grid>
        <Border Background="#3A3A4A" CornerRadius="15" Margin="20">
            <StackPanel Margin="30" VerticalAlignment="Center">
                <TextBlock x:Name="EnglishWord" FontSize="48" FontWeight="Bold" 
                           Foreground="#FFD966" HorizontalAlignment="Center"
                           FontFamily="Segoe UI"/>

                <TextBlock x:Name="RussianWord" FontSize="28" Foreground="White" 
                           HorizontalAlignment="Center" Margin="0,20,0,20"/>

                <TextBox x:Name="TypingBox" Height="50" FontSize="24" 
                         HorizontalAlignment="Center" Width="300" Margin="10"
                         BorderBrush="#FFD966" BorderThickness="2"
                         KeyDown="TypingBox_KeyDown"/>

                <Button Content="✅ ПРОВЕРИТЬ" Width="180" Height="45" 
                        Background="#4A90E2" Foreground="White" FontSize="18"
                        Cursor="Hand" Click="Check_Click" Margin="10"/>

                <TextBlock x:Name="HintText" Foreground="#AAAAAA" 
                           HorizontalAlignment="Center" FontSize="14"
                           TextWrapping="Wrap" TextAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
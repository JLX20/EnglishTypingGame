<Window x:Class="EnglishTypingGame.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="English Typing Game"
        Height="720"
        Width="1050"
        MinHeight="680"
        MinWidth="950"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{DynamicResource WindowBgBrush}">

    <Grid Margin="26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="English Typing Game"
                       FontSize="{DynamicResource TitleFontSize}"
                       FontWeight="Bold"
                       TextWrapping="Wrap"/>

            <TextBlock Text="Изучай английские слова, правила и предложения через мини-игры."
                       FontSize="{DynamicResource SubtitleFontSize}"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Margin="0,6,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="{DynamicResource CardBgBrush}"
                CornerRadius="30"
                Padding="26"
                Effect="{StaticResource CardShadow}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.15*"/>
                    <ColumnDefinition Width="0.85*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,24,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Главное меню"
                               FontSize="{DynamicResource PromptFontSize}"
                               FontWeight="Bold"
                               TextWrapping="Wrap"
                               Margin="0,0,0,14"/>

                    <StackPanel Grid.Row="1" Margin="0,0,0,12">
                        <TextBlock Text="Выбери тему слов"
                                   FontSize="{DynamicResource NormalFontSize}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>

                        <ComboBox x:Name="TopicComboBox"
                                  Height="46"
                                  Margin="0,8,0,0"/>
                    </StackPanel>

                    <UniformGrid Grid.Row="2"
                                 Columns="1"
                                 Rows="8"
                                 VerticalAlignment="Stretch">

                        <Button Content="1. Изучать слова"
                                Background="{DynamicResource ButtonMainBrush}"
                                FontSize="{DynamicResource ButtonFontSize}"
                                Click="LearnButton_Click"/>

                        <Button Content="2. Изучать правила"
                                Background="{DynamicResource ButtonMainBrush}"
                                FontSize="{DynamicResource ButtonFontSize}"
                                Click="GrammarButton_Click"/>

                        <Button Content="3. Мини-игры после изучения"
                                Background="{DynamicResource ButtonMainBrush}"
                                FontSize="{DynamicResource ButtonFontSize}"
                                Click="MiniGamesButton_Click"/>

                        <Button Content="4. Обычная игра: перевод → английское слово"
                                Background="{DynamicResource ButtonMainBrush}"
                                FontSize="{DynamicResource ButtonFontSize}"
                                Click="ClassicGameButton_Click"/>

                        <Button Content="5. Тренировать ошибки"
                                Background="{DynamicResource ButtonMainBrush}"
                                FontSize="{DynamicResource ButtonFontSize}"
                                Click="MistakesButton_Click"/>

                        <Button Content="Мой прогресс"
                                Background="{DynamicResource ButtonMainBrush}"
                                FontSize="{DynamicResource ButtonFontSize}"
                                Click="ProgressButton_Click"/>

                        <Button Content="Настройки"
                                Background="{DynamicResource ButtonMainBrush}"
                                FontSize="{DynamicResource ButtonFontSize}"
                                Click="SettingsButton_Click"/>

                        <Button Content="Выход"
                                Background="{DynamicResource ButtonNeutralBrush}"
                                FontSize="{DynamicResource ButtonFontSize}"
                                Click="ExitButton_Click"/>
                    </UniformGrid>
                </Grid>

                <Border Grid.Column="1"
                        Background="{DynamicResource SoftBgBrush}"
                        CornerRadius="26"
                        Padding="22">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Твой прогресс"
                                   FontSize="{DynamicResource PromptFontSize}"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"/>

                        <TextBlock x:Name="StatsText"
                                   Grid.Row="1"
                                   FontSize="{DynamicResource NormalFontSize}"
                                   Foreground="{DynamicResource DarkTextBrush}"
                                   LineHeight="28"
                                   TextWrapping="Wrap"/>

                        <Border Grid.Row="2"
                                Background="{DynamicResource CardBgBrush}"
                                CornerRadius="22"
                                Padding="16"
                                Margin="0,12,0,0">

                            <TextBlock FontSize="{DynamicResource SmallFontSize}"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       LineHeight="24"
                                       TextWrapping="Wrap">
                                Рекомендуемый путь: изучи слова → изучи правила → пройди мини-игры → повтори ошибки.
                            </TextBlock>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
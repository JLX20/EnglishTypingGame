<Window x:Class="EnglishTypingGame.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="English Typing Game"
        Height="850"
        Width="950"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="{DynamicResource WindowBgBrush}">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="English Typing Game"
                       FontSize="40"
                       FontWeight="Bold"/>

            <TextBlock Text="Изучай английские слова, грамматику и предложения через мини-игры."
                       FontSize="17"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Margin="0,8,0,0"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="{DynamicResource CardBgBrush}"
                CornerRadius="30"
                Padding="28"
                Effect="{StaticResource CardShadow}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.15*"/>
                    <ColumnDefinition Width="0.85*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Главное меню"
                               FontSize="27"
                               FontWeight="Bold"
                               Margin="0,0,0,18"/>

                    <TextBlock Text="Выбери тему слов"
                               FontSize="17"
                               FontWeight="SemiBold"/>

                    <ComboBox x:Name="TopicComboBox"
                              Height="46"
                              Margin="0,8,0,20"/>

                    <Button Content="1. Изучать слова"
                            Height="50"
                            Background="{DynamicResource ButtonMainBrush}"
                            Click="LearnButton_Click"/>

                    <Button Content="2. Мини-игры после изучения"
                            Height="50"
                            Background="{DynamicResource ButtonMainBrush}"
                            Click="MiniGamesButton_Click"/>

                    <Button Content="3. Обычная игра: перевод → английское слово"
                            Height="50"
                            Background="{DynamicResource ButtonMainBrush}"
                            Click="ClassicGameButton_Click"/>

                    <Button Content="4. Тренировать ошибки"
                            Height="50"
                            Background="{DynamicResource ButtonMainBrush}"
                            Click="MistakesButton_Click"/>

                    <Button Content="Мой прогресс"
                            Height="50"
                            Background="{DynamicResource ButtonMainBrush}"
                            Click="ProgressButton_Click"/>

                    <Button Content="Настройки"
                            Height="50"
                            Background="{DynamicResource ButtonMainBrush}"
                            Click="SettingsButton_Click"/>

                    <Button Content="Выход"
                            Height="50"
                            Background="{DynamicResource ButtonNeutralBrush}"
                            Click="ExitButton_Click"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="{DynamicResource SoftBgBrush}"
                        CornerRadius="26"
                        Padding="24"
                        Margin="26,0,0,0">

                    <StackPanel>
                        <TextBlock Text="Твой прогресс"
                                   FontSize="25"
                                   FontWeight="Bold"
                                   Margin="0,0,0,16"/>

                        <TextBlock x:Name="StatsText"
                                   FontSize="16"
                                   Foreground="{DynamicResource DarkTextBrush}"
                                   LineHeight="30"
                                   TextWrapping="Wrap"/>

                        <Separator Margin="0,20,0,18"/>

                        <TextBlock Text="Рекомендуемый путь:"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>

                        <TextBlock FontSize="15"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   LineHeight="28"
                                   TextWrapping="Wrap">
                            1. Изучи слова в карточках&#x0a;
                            2. Пройди мини-игры по словам&#x0a;
                            3. Пройди мини-игры по грамматике&#x0a;
                            4. Повтори ошибки&#x0a;
                            5. Открой новую тему
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
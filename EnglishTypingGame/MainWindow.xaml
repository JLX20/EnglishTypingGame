<Window x:Class="EnglishTypingGame.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🎵 TYPING RAIN DANCE" Height="500" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Background="#2D2D3D" Padding="20" Grid.Row="0">
            <TextBlock Text="🎵 TYPING RAIN DANCE 🎵" FontSize="36" FontWeight="Bold"
                       HorizontalAlignment="Center" Foreground="#FFD966"
                       FontFamily="Segoe UI">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.5"/>
                </TextBlock.Effect>
            </TextBlock>
        </Border>

        <!-- Кнопки меню -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Button x:Name="LevelsBtn" Content="📚 УРОВНИ" Width="300" Height="60" FontSize="22"
                    Background="#4A90E2" Foreground="White" FontWeight="Bold"
                    Cursor="Hand" Click="LevelsBtn_Click" Margin="0,10"/>

            <Button x:Name="CardsBtn" Content="📖 ВСЕ КАРТОЧКИ" Width="300" Height="60" FontSize="22"
                    Background="#50C878" Foreground="White" FontWeight="Bold"
                    Cursor="Hand" Click="CardsBtn_Click" Margin="0,10"/>

            <Button x:Name="SettingsBtn" Content="⚙ НАСТРОЙКИ" Width="300" Height="60" FontSize="22"
                    Background="#888888" Foreground="White" FontWeight="Bold"
                    Cursor="Hand" Click="SettingsBtn_Click" Margin="0,10"/>

            <Button x:Name="ExitBtn" Content="🚪 ВЫХОД" Width="300" Height="60" FontSize="22"
                    Background="#E2542E" Foreground="White" FontWeight="Bold"
                    Cursor="Hand" Click="ExitBtn_Click" Margin="0,10"/>
        </StackPanel>

        <!-- Футер -->
        <Border Background="#2D2D3D" Padding="10" Grid.Row="2">
            <TextBlock Text="© 2025 | Учи английский с ритмом | Твой темп — твой успех"
                       HorizontalAlignment="Center" Foreground="#AAAAAA" FontSize="14"/>
        </Border>
    </Grid>
</Window>
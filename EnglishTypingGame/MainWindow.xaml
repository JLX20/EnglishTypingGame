<Window x:Class="EnglishTypingGame.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="English Typing Game"
        Height="760"
        Width="1120"
        MinHeight="700"
        MinWidth="980"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{DynamicResource WindowBgBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="English Typing Game"
                       FontSize="{DynamicResource TitleFontSize}"
                       FontWeight="Bold"
                       TextWrapping="Wrap"/>

            <TextBlock Text="Выбери тему, сложность и режим обучения."
                       FontSize="{DynamicResource SubtitleFontSize}"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="{DynamicResource CardBgBrush}"
                CornerRadius="30"
                Padding="24"
                Effect="{StaticResource CardShadow}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="0.8*"/>
                        <ColumnDefinition Width="1.1*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Тема слов"
                                   FontSize="{DynamicResource NormalFontSize}"
                                   FontWeight="SemiBold"/>
                        <ComboBox x:Name="TopicComboBox"
                                  Height="46"
                                  Margin="0,8,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="Сложность"
                                   FontSize="{DynamicResource NormalFontSize}"
                                   FontWeight="SemiBold"/>
                        <ComboBox x:Name="LevelComboBox"
                                  Height="46"
                                  Margin="0,8,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Режим обычной игры"
                                   FontSize="{DynamicResource NormalFontSize}"
                                   FontWeight="SemiBold"/>
                        <ComboBox x:Name="InputModeComboBox"
                                  Height="46"
                                  Margin="0,8,0,0">
                            <ComboBoxItem Content="Русский → английский" Tag="RussianToEnglish"/>
                            <ComboBoxItem Content="Английский → русский" Tag="EnglishToRussian"/>
                            <ComboBoxItem Content="Пример → вставить слово" Tag="ExampleToWord"/>
                            <ComboBoxItem Content="Смешанный режим ввода" Tag="Mixed"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.4*"/>
                        <ColumnDefinition Width="0.9*"/>
                    </Grid.ColumnDefinitions>

                    <UniformGrid Grid.Column="0"
                                 Columns="2"
                                 Rows="4"
                                 Margin="0,0,20,0">

                        <Button Content="📚 Изучать слова"
                                FontSize="{DynamicResource ButtonFontSize}"
                                Background="{DynamicResource ButtonMainBrush}"
                                Click="LearnButton_Click"/>

                        <Button Content="🧠 Изучать правила"
                                FontSize="{DynamicResource ButtonFontSize}"
                                Background="{DynamicResource ButtonMainBrush}"
                                Click="GrammarButton_Click"/>

                        <Button Content="🗺 Карта прохождения"
                                FontSize="{DynamicResource ButtonFontSize}"
                                Background="{DynamicResource ButtonMainBrush}"
                                Click="StudyPathButton_Click"/>

                        <Button Content="🎮 Мини-игры"
                                FontSize="{DynamicResource ButtonFontSize}"
                                Background="{DynamicResource ButtonMainBrush}"
                                Click="MiniGamesButton_Click"/>

                        <Button Content="🔀 Смешанная тренировка"
                                FontSize="{DynamicResource ButtonFontSize}"
                                Background="{DynamicResource ButtonAccentBrush}"
                                Click="MixedTrainingButton_Click"/>

                        <Button Content="⌨ Обычная игра"
                                FontSize="{DynamicResource ButtonFontSize}"
                                Background="{DynamicResource ButtonMainBrush}"
                                Click="ClassicGameButton_Click"/>

                        <Button Content="❌ Тренировать ошибки"
                                FontSize="{DynamicResource ButtonFontSize}"
                                Background="{DynamicResource ButtonWarningBrush}"
                                Click="MistakesButton_Click"/>

                        <Button Content="📊 Мой прогресс"
                                FontSize="{DynamicResource ButtonFontSize}"
                                Background="{DynamicResource ButtonSuccessBrush}"
                                Click="ProgressButton_Click"/>
                    </UniformGrid>

                    <Border Grid.Column="1"
                            Background="{DynamicResource SoftBgBrush}"
                            CornerRadius="26"
                            Padding="20">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Твой прогресс"
                                       FontSize="{DynamicResource PromptFontSize}"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12"/>

                            <TextBlock x:Name="StatsText"
                                       Grid.Row="1"
                                       FontSize="{DynamicResource NormalFontSize}"
                                       LineHeight="28"
                                       TextWrapping="Wrap"/>

                            <Button Grid.Row="2"
                                    Content="⚙ Настройки"
                                    Height="48"
                                    FontSize="{DynamicResource ButtonFontSize}"
                                    Background="{DynamicResource ButtonNeutralBrush}"
                                    Click="SettingsButton_Click"/>
                        </Grid>
                    </Border>
                </Grid>

                <Button Grid.Row="2"
                        Content="Выход"
                        Width="120"
                        Height="46"
                        HorizontalAlignment="Right"
                        FontSize="{DynamicResource ButtonFontSize}"
                        Background="{DynamicResource ButtonNeutralBrush}"
                        Click="ExitButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
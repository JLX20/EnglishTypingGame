<Window x:Class="EnglishTypingGame.StudyPathWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Карта прохождения"
        Height="760"
        Width="1080"
        MinHeight="700"
        MinWidth="940"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource WindowBgBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Карта прохождения"
                       FontSize="{DynamicResource TitleFontSize}"
                       FontWeight="Bold"/>

            <TextBlock x:Name="TopicText"
                       FontSize="{DynamicResource SubtitleFontSize}"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="{DynamicResource CardBgBrush}"
                CornerRadius="30"
                Padding="24"
                Effect="{StaticResource CardShadow}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource SoftBgBrush}"
                        CornerRadius="22"
                        Padding="16"
                        Margin="0,0,0,18">

                    <TextBlock x:Name="SummaryText"
                               FontSize="{DynamicResource NormalFontSize}"
                               TextWrapping="Wrap"
                               LineHeight="28"/>
                </Border>

                <UniformGrid Grid.Row="1"
                             Columns="3"
                             Rows="2">

                    <Button x:Name="WordsButton"
                            Content="1. Изучить слова"
                            FontSize="{DynamicResource ButtonFontSize}"
                            Background="{DynamicResource ButtonMainBrush}"
                            Click="WordsButton_Click"/>

                    <Button x:Name="RulesButton"
                            Content="2. Изучить правила"
                            FontSize="{DynamicResource ButtonFontSize}"
                            Background="{DynamicResource ButtonMainBrush}"
                            Click="RulesButton_Click"/>

                    <Button x:Name="MiniGamesButton"
                            Content="3. Мини-игры"
                            FontSize="{DynamicResource ButtonFontSize}"
                            Background="{DynamicResource ButtonMainBrush}"
                            Click="MiniGamesButton_Click"/>

                    <Button x:Name="MixedButton"
                            Content="4. Смешанная тренировка"
                            FontSize="{DynamicResource ButtonFontSize}"
                            Background="{DynamicResource ButtonAccentBrush}"
                            Click="MixedButton_Click"/>

                    <Button x:Name="FinalGameButton"
                            Content="5. Финальная обычная игра"
                            FontSize="{DynamicResource ButtonFontSize}"
                            Background="{DynamicResource ButtonSuccessBrush}"
                            Click="FinalGameButton_Click"/>

                    <Button x:Name="ProgressButton"
                            Content="6. Посмотреть прогресс"
                            FontSize="{DynamicResource ButtonFontSize}"
                            Background="{DynamicResource ButtonNeutralBrush}"
                            Click="ProgressButton_Click"/>
                </UniformGrid>
            </Grid>
        </Border>

        <Button Grid.Row="2"
                Content="В меню"
                Width="120"
                Height="48"
                HorizontalAlignment="Right"
                Margin="0,14,0,0"
                FontSize="{DynamicResource ButtonFontSize}"
                Background="{DynamicResource ButtonNeutralBrush}"
                Click="CloseButton_Click"/>
    </Grid>
</Window>
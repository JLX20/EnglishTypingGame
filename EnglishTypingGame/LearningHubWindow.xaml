<Window x:Class="EnglishTypingGame.LearningHubWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📖 ОБУЧЕНИЕ" Height="650" Width="800"
        WindowStartupLocation="CenterOwner" Background="#2C2C3E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="#3A3A4A" Padding="15" Grid.Row="0">
            <TextBlock x:Name="LevelTitle" Text="УРОВЕНЬ 1" FontSize="24" FontWeight="Bold"
                       Foreground="#FFD966" HorizontalAlignment="Center"/>
        </Border>

        <Border Background="#2D2D3D" Padding="10" Grid.Row="1">
            <TextBlock x:Name="ProgressText" Text="Прогресс: 0/5 слов" 
                       Foreground="White" FontSize="16" HorizontalAlignment="Center"/>
        </Border>

        <DataGrid Grid.Row="2" x:Name="WordsGrid" AutoGenerateColumns="False" 
                  Background="#3A3A4A" Foreground="White" Margin="20"
                  HeadersVisibility="Column" FontSize="14" RowHeight="40"
                  AlternatingRowBackground="#4A4A5A">
            <DataGrid.Columns>
                <DataGridTextColumn Header="🇬🇧 Слово" Binding="{Binding English}" Width="150"/>
                <DataGridTextColumn Header="🇷🇺 Перевод" Binding="{Binding Russian}" Width="150"/>
                <DataGridCheckBoxColumn Header="✅ Выучено" Binding="{Binding IsLearned}" 
                                        IsReadOnly="True" Width="100"/>
                <DataGridTemplateColumn Header="📚 Действие" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Учить" Click="LearnWord_Click" 
                                    Tag="{Binding English}" Width="80" Height="30"
                                    Background="#4A90E2" Foreground="White"
                                    Margin="5"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Background="#3A3A4A" Padding="15" Grid.Row="3">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="🎓 ПРОЙТИ ТЕСТ-ДРАЙВ" Width="200" Height="45" 
                        Background="#4A90E2" Foreground="White" FontSize="16"
                        Cursor="Hand" Click="StartTest_Click" Margin="5"/>
                <Button Content="🔙 НАЗАД" Width="120" Height="45" 
                        Background="#888888" Foreground="White" FontSize="16"
                        Cursor="Hand" Click="Back_Click" Margin="5"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
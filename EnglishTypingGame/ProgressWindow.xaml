<Window x:Class="EnglishTypingGame.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Прогресс"
        Height="720"
        Width="1050"
        MinHeight="680"
        MinWidth="920"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource WindowBgBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Мой прогресс"
                   FontSize="{DynamicResource TitleFontSize}"
                   FontWeight="Bold"
                   TextWrapping="Wrap"
                   Margin="0,0,0,14"/>

        <Border Grid.Row="1"
                Background="{DynamicResource CardBgBrush}"
                CornerRadius="30"
                Padding="22"
                Effect="{StaticResource CardShadow}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.9*"/>
                    <ColumnDefinition Width="1.1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{DynamicResource SoftBgBrush}"
                        CornerRadius="26"
                        Padding="22"
                        Margin="0,0,18,0">

                    <TextBlock x:Name="ProgressText"
                               FontSize="{DynamicResource NormalFontSize}"
                               LineHeight="30"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"/>
                </Border>

                <Border Grid.Column="1"
                        Background="{DynamicResource SoftBgBrush}"
                        CornerRadius="26"
                        Padding="14">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Слова с ошибками"
                                   FontSize="{DynamicResource PromptFontSize}"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"/>

                        <DataGrid x:Name="MistakesGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="English"
                                                    Binding="{Binding English}"
                                                    Width="*"/>

                                <DataGridTextColumn Header="Русский"
                                                    Binding="{Binding Russian}"
                                                    Width="*"/>

                                <DataGridTextColumn Header="Ошибок"
                                                    Binding="{Binding Count}"
                                                    Width="80"/>

                                <DataGridTextColumn Header="Последний ответ"
                                                    Binding="{Binding LastWrongAnswer}"
                                                    Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <WrapPanel Grid.Row="2"
                   HorizontalAlignment="Right"
                   Margin="0,14,0,0">

            <Button Content="Сбросить прогресс"
                    Width="180"
                    Height="48"
                    FontSize="{DynamicResource ButtonFontSize}"
                    Background="{DynamicResource ButtonDangerBrush}"
                    Click="ResetButton_Click"/>

            <Button Content="В меню"
                    Width="120"
                    Height="48"
                    FontSize="{DynamicResource ButtonFontSize}"
                    Background="{DynamicResource ButtonNeutralBrush}"
                    Click="CloseButton_Click"/>
        </WrapPanel>
    </Grid>
</Window>
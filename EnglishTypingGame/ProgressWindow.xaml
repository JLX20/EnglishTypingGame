<Window x:Class="EnglishTypingGame.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Прогресс"
        Height="740"
        Width="1120"
        MinHeight="700"
        MinWidth="980"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource WindowBgBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Мой прогресс"
                   FontSize="{DynamicResource TitleFontSize}"
                   FontWeight="Bold"
                   Margin="0,0,0,14"/>

        <Border Grid.Row="1"
                Background="{DynamicResource CardBgBrush}"
                CornerRadius="30"
                Padding="22"
                Effect="{StaticResource CardShadow}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.85*"/>
                    <ColumnDefinition Width="1.15*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,18,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource SoftBgBrush}"
                            CornerRadius="26"
                            Padding="20"
                            Margin="0,0,0,16">

                        <TextBlock x:Name="ProgressText"
                                   FontSize="{DynamicResource NormalFontSize}"
                                   LineHeight="28"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <Border Grid.Row="1"
                            Background="{DynamicResource SoftBgBrush}"
                            CornerRadius="26"
                            Padding="14">

                        <DataGrid x:Name="MistakesGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="English"
                                                    Binding="{Binding English}"
                                                    Width="*"/>

                                <DataGridTextColumn Header="Русский"
                                                    Binding="{Binding Russian}"
                                                    Width="*"/>

                                <DataGridTextColumn Header="Ошибок"
                                                    Binding="{Binding Count}"
                                                    Width="75"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>

                <Border Grid.Column="1"
                        Background="{DynamicResource SoftBgBrush}"
                        CornerRadius="26"
                        Padding="16">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Статистика по темам"
                                   FontSize="{DynamicResource PromptFontSize}"
                                   FontWeight="Bold"
                                   Margin="0,0,0,12"/>

                        <DataGrid x:Name="TopicStatsGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Тема"
                                                    Binding="{Binding TopicName}"
                                                    Width="2*"/>

                                <DataGridTextColumn Header="Выучено"
                                                    Binding="{Binding LearnedWords}"
                                                    Width="90"/>

                                <DataGridTextColumn Header="Всего"
                                                    Binding="{Binding TotalWords}"
                                                    Width="75"/>

                                <DataGridTextColumn Header="%"
                                                    Binding="{Binding LearnedPercent, StringFormat=0.0}"
                                                    Width="80"/>

                                <DataGridTextColumn Header="Ошибки"
                                                    Binding="{Binding MistakeWords}"
                                                    Width="80"/>

                                <DataGridTextColumn Header="Звёзды"
                                                    Binding="{Binding StarsText}"
                                                    Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <WrapPanel Grid.Row="2"
                   HorizontalAlignment="Right"
                   Margin="0,14,0,0">

            <Button Content="Сбросить прогресс"
                    Width="180"
                    Height="48"
                    FontSize="{DynamicResource ButtonFontSize}"
                    Background="{DynamicResource ButtonDangerBrush}"
                    Click="ResetButton_Click"/>

            <Button Content="В меню"
                    Width="120"
                    Height="48"
                    FontSize="{DynamicResource ButtonFontSize}"
                    Background="{DynamicResource ButtonNeutralBrush}"
                    Click="CloseButton_Click"/>
        </WrapPanel>
    </Grid>
</Window>
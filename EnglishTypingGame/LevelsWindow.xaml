<Window x:Class="EnglishTypingGame.LevelsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📚 ВЫБОР УРОВНЯ" Height="600" Width="800"
        WindowStartupLocation="CenterOwner" Background="#2C2C3E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="#3A3A4A" Padding="20" Grid.Row="0">
            <TextBlock Text="ВЫБЕРИТЕ УРОВЕНЬ" FontSize="28" FontWeight="Bold" 
                       HorizontalAlignment="Center" Foreground="#FFD966"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <WrapPanel x:Name="LevelsList" Margin="30"/>
        </ScrollViewer>

        <Border Background="#3A3A4A" Padding="15" Grid.Row="2">
            <Button Content="🔙 НАЗАД В МЕНЮ" Width="150" Height="40" 
                    Background="#888888" Foreground="White" FontSize="16"
                    Cursor="Hand" Click="Back_Click" HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
<Window x:Class="EnglishTypingGame.TestDriveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🎯 ТЕСТ-ДРАЙВ" Height="450" Width="600"
        WindowStartupLocation="CenterOwner" Background="#2C2C3E">
    <Grid>
        <Border Background="#3A3A4A" CornerRadius="15" Margin="20">
            <StackPanel Margin="30">
                <TextBlock Text="ПРОВЕРКА ЗНАНИЙ" FontSize="28" FontWeight="Bold"
                           Foreground="#FFD966" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock x:Name="QuestionText" Text="Слово 1 из 5" FontSize="16"
                           Foreground="White" HorizontalAlignment="Center"/>

                <Border Background="#2D2D3D" CornerRadius="10" Padding="30" Margin="0,20">
                    <TextBlock x:Name="RussianWord" FontSize="32" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"/>
                </Border>

                <TextBox x:Name="AnswerBox" Height="45" FontSize="22" 
                         HorizontalAlignment="Center" Width="280" Margin="10"
                         BorderBrush="#FFD966" BorderThickness="2"
                         KeyDown="AnswerBox_KeyDown"/>

                <TextBlock x:Name="ScoreText" Text="✅ Правильно: 0 | ❌ Ошибок: 0"
                           Foreground="#AAAAAA" FontSize="14" Margin="0,20,0,0"
                           HorizontalAlignment="Center"/>

                <Button x:Name="NextButton" Content="➡ ДАЛЕЕ" Width="150" Height="40"
                        Background="#4A90E2" Foreground="White" FontSize="16"
                        Cursor="Hand" Click="NextButton_Click" Visibility="Collapsed"
                        HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
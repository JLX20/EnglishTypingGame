<Window x:Class="EnglishTypingGame.RhythmGameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🎵 TYPING RAIN DANCE - ИГРА" Height="600" Width="900"
        WindowStartupLocation="CenterScreen" Background="#1E1E2E"
        Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Background="#2D2D3D" Padding="15" Grid.Row="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="❤️ Здоровье: " Foreground="White" FontSize="16"/>
                    <TextBlock x:Name="HealthText" Text="10" Foreground="#FF6666" FontSize="16" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="🎯 Счёт: " Foreground="White" FontSize="16"/>
                    <TextBlock x:Name="ScoreText" Text="0" Foreground="#FFD966" FontSize="16" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="⚡ Комбо: " Foreground="White" FontSize="16"/>
                    <TextBlock x:Name="ComboText" Text="0" Foreground="#50C878" FontSize="16" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Игровое поле для падающих букв -->
        <Canvas x:Name="GameCanvas" Grid.Row="1" Background="#2C2C3E"
                ClipToBounds="True" Focusable="True" KeyDown="GameCanvas_KeyDown"
                Loaded="GameCanvas_Loaded">

            <!-- Ритмическая линия внизу -->
            <Border x:Name="RhythmLine" Height="4" Background="#FFD966"
                    Canvas.Bottom="80" Width="900" HorizontalAlignment="Stretch"/>

            <!-- Подсказка текущего слова -->
            <Border Background="#3A3A4A" CornerRadius="10" Padding="10,5"
                    Canvas.Bottom="100" Canvas.Left="20">
                <TextBlock x:Name="CurrentWordHint" Text="Слово: " Foreground="#FFD966" FontSize="14"/>
            </Border>

            <!-- Индикатор ритма -->
            <Ellipse x:Name="RhythmPulse" Width="20" Height="20" Fill="#4A90E2"
                     Canvas.Bottom="70" Canvas.Right="30" Opacity="0.8"/>
        </Canvas>

        <!-- Нижняя панель ввода -->
        <Border Background="#2D2D3D" Padding="15" Grid.Row="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="InputTextBox" FontSize="24" Height="50" 
                         VerticalContentAlignment="Center" Background="#3A3A4A"
                         Foreground="White" BorderBrush="#FFD966" BorderThickness="2"
                         KeyDown="InputTextBox_KeyDown"/>

                <Button Grid.Column="1" Content="🚪 Выход" Width="100" Height="50"
                        Background="#E2542E" Foreground="White" FontSize="16"
                        Cursor="Hand" Click="ExitButton_Click" Margin="10,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
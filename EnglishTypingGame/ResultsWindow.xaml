<Window x:Class="EnglishTypingGame.ResultsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Результаты"
        Height="700"
        Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBgBrush}">

    <Grid Margin="30">
        <Border Background="{DynamicResource CardBgBrush}"
                CornerRadius="30"
                Padding="30"
                Effect="{StaticResource CardShadow}">

            <StackPanel>
                <TextBlock x:Name="TitleText"
                           FontSize="31"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>

                <Border Background="{DynamicResource SoftBgBrush}"
                        CornerRadius="24"
                        Padding="22"
                        Margin="0,28,0,22">

                    <TextBlock x:Name="ResultText"
                               FontSize="18"
                               Foreground="{DynamicResource DarkTextBrush}"
                               LineHeight="34"/>
                </Border>

                <Border Background="{DynamicResource SoftBgBrush}"
                        CornerRadius="24"
                        Padding="18"
                        Margin="0,0,0,22">

                    <TextBlock x:Name="AdviceText"
                               FontSize="16"
                               TextWrapping="Wrap"
                               LineHeight="26"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                </Border>

                <Button Content="Вернуться в меню"
                        Height="48"
                        Background="{DynamicResource ButtonMainBrush}"
                        Click="CloseButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
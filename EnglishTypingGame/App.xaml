<Application x:Class="EnglishTypingGame.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">

    <Application.Resources>

        <!-- BACKGROUND -->
        <SolidColorBrush x:Key="WindowBgBrush" Color="#E0F2FE"/>
        <SolidColorBrush x:Key="CardBgBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SoftBgBrush" Color="#F1F5F9"/>

        <!-- TEXT -->
        <SolidColorBrush x:Key="DarkTextBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#64748B"/>

        <!-- SAFE INPUT COLORS -->
        <!-- Эти цвета специально не зависят от темы, чтобы текст всегда был виден -->
        <SolidColorBrush x:Key="InputBgBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="InputTextBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="InputBorderBrush" Color="#2563EB"/>

        <!-- BUTTONS -->
        <SolidColorBrush x:Key="ButtonMainBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="ButtonAccentBrush" Color="#7C3AED"/>
        <SolidColorBrush x:Key="ButtonSuccessBrush" Color="#059669"/>
        <SolidColorBrush x:Key="ButtonWarningBrush" Color="#EA580C"/>
        <SolidColorBrush x:Key="ButtonDangerBrush" Color="#DC2626"/>
        <SolidColorBrush x:Key="ButtonNeutralBrush" Color="#64748B"/>

        <!-- OLD BRUSH NAMES FOR COMPATIBILITY -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#1D4ED8"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#3B82F6"/>
        <SolidColorBrush x:Key="GreenBrush" Color="#059669"/>
        <SolidColorBrush x:Key="PurpleBrush" Color="#7C3AED"/>
        <SolidColorBrush x:Key="RedBrush" Color="#DC2626"/>
        <SolidColorBrush x:Key="OrangeBrush" Color="#EA580C"/>
        <SolidColorBrush x:Key="TealBrush" Color="#0F766E"/>
        <SolidColorBrush x:Key="SlateBrush" Color="#475569"/>
        <SolidColorBrush x:Key="GrayButtonBrush" Color="#64748B"/>

        <!-- FONT SIZES -->
        <sys:Double x:Key="TitleFontSize" xmlns:sys="clr-namespace:System;assembly=mscorlib">34</sys:Double>
        <sys:Double x:Key="SubtitleFontSize" xmlns:sys="clr-namespace:System;assembly=mscorlib">16</sys:Double>
        <sys:Double x:Key="NormalFontSize" xmlns:sys="clr-namespace:System;assembly=mscorlib">16</sys:Double>
        <sys:Double x:Key="SmallFontSize" xmlns:sys="clr-namespace:System;assembly=mscorlib">14</sys:Double>
        <sys:Double x:Key="ButtonFontSize" xmlns:sys="clr-namespace:System;assembly=mscorlib">15</sys:Double>
        <sys:Double x:Key="InputFontSize" xmlns:sys="clr-namespace:System;assembly=mscorlib">24</sys:Double>
        <sys:Double x:Key="PromptFontSize" xmlns:sys="clr-namespace:System;assembly=mscorlib">40</sys:Double>
        <sys:Double x:Key="WordFontSize" xmlns:sys="clr-namespace:System;assembly=mscorlib">54</sys:Double>
        <sys:Double x:Key="PreviewFontSize" xmlns:sys="clr-namespace:System;assembly=mscorlib">30</sys:Double>

        <!-- SHADOWS -->
        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="18"
                          ShadowDepth="2"
                          Opacity="0.12"
                          Color="#000000"/>

        <DropShadowEffect x:Key="SoftShadow"
                          BlurRadius="10"
                          ShadowDepth="1"
                          Opacity="0.10"
                          Color="#000000"/>

        <!-- WINDOW -->
        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Background" Value="{DynamicResource WindowBgBrush}"/>
        </Style>

        <!-- TEXT -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource DarkTextBrush}"/>
        </Style>

        <!-- BUTTON -->
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Background" Value="{DynamicResource ButtonMainBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="{DynamicResource ButtonFontSize}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="22"
                                Padding="{TemplateBinding Padding}"
                                Effect="{StaticResource SoftShadow}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.90"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.75"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SAFE TEXTBOX -->
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="{DynamicResource InputFontSize}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="MinHeight" Value="56"/>
            <Setter Property="Height" Value="Auto"/>
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource InputTextBrush}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource InputTextBrush}"/>
            <Setter Property="SelectionBrush" Value="#93C5FD"/>
            <Setter Property="SelectionOpacity" Value="0.65"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="AcceptsReturn" Value="False"/>
            <Setter Property="ClipToBounds" Value="True"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TextBoxBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource InputBorderBrush}"
                                BorderThickness="2"
                                CornerRadius="18"
                                Padding="{TemplateBinding Padding}"
                                Effect="{StaticResource SoftShadow}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="Center"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="TextBoxBorder"
                                        Property="BorderBrush"
                                        Value="{DynamicResource ButtonMainBrush}"/>
                                <Setter TargetName="TextBoxBorder"
                                        Property="BorderThickness"
                                        Value="3"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="TextBoxBorder"
                                        Property="Opacity"
                                        Value="0.65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- COMBOBOX -->
        <Style TargetType="ComboBox">
            <Setter Property="FontSize" Value="{DynamicResource NormalFontSize}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="MinHeight" Value="44"/>
        </Style>

        <!-- CHECKBOX -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource DarkTextBrush}"/>
            <Setter Property="FontSize" Value="{DynamicResource NormalFontSize}"/>
            <Setter Property="Margin" Value="0,7"/>
        </Style>

        <!-- LISTBOX -->
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>

        <!-- DATAGRID -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource DarkTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#E2E8F0"/>
            <Setter Property="Foreground" Value="{DynamicResource DarkTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- PROGRESS BAR -->
        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="14"/>
            <Setter Property="Background" Value="#E2E8F0"/>
            <Setter Property="Foreground" Value="{DynamicResource ButtonMainBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

    </Application.Resources>
</Application>